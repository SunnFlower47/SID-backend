APP_NAME=
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=localhost
LANDLORD_DOMAIN=diskominfo.sistem-desa-cibatu.test
ADMIN_DOMAIN=admin.sistem-desa-cibatu.test


RECAPTCHA_ENABLED=false
RECAPTCHA_V3_MIN_SCORE=0.5

# reCAPTCHA v2
RECAPTCHA_V2_SITE_KEY=YOUR-RECAPTCHA_V2_SITE_KEY
RECAPTCHA_V2_SECRET_KEY=YOUR-RECAPTCHA_V2_SECRET_KEY
# reCAPTCHA v3
RECAPTCHA_V3_SITE_KEY=YOUR-RECAPTCHA_V3_SITE_KEY   
RECAPTCHA_V3_SECRET_KEY=YOUR-RECAPTCHA_V3_SECRET_KEY
# API Security
API_KEY=API_KEY_TESTING_PURPOSE_2026
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3030,http://127.0.0.1:3000,http://sistem-desa-cibatu.test,https://pemdescibatu2001.online,https://api-vilage.sunnflower.site,https://vilage.sunnflower.site,https://cibatu-vibe-ai-505268805663.asia-southeast2.run.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=
# DB_USERNAME=root
# DB_PASSWORD=

# CACHE SETTINGS - OPTIMIZED FOR FILE CACHE
CACHE_STORE=file
CACHE_PREFIX=laravel_cache

# SESSION SETTINGS - OPTIMIZED FOR FILE SESSION
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
# QUEUE SETTINGS - OPTIMIZED FOR SYNC QUEUE
QUEUE_CONNECTION=sync

# BROADCASTING SETTINGS
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

# REDIS SETTINGS (COMMENTED OUT - UNCOMMENT WHEN REDIS AVAILABLE)
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MAIL_MAILER=smtp
# MAIL_HOST=
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=

# MAIL_FROM_ADDRESS=
# MAIL_FROM_NAME=

# AWS SETTINGS
AWS_ACCESS_KEY_ID=desadmin
AWS_SECRET_ACCESS_KEY=desadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=cibatu-storage
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://127.0.0.1:9000
# MEMCACHED SETTINGS
MEMCACHED_HOST=127.0.0.1

# VITE SETTINGS
VITE_APP_NAME="${APP_NAME}"

# OPTIMIZATION SETTINGS
OPCACHE_ENABLE=true


